local function getPlayerRole(plr)
    if not plr.Character then return "Innocent" end
    local backpack = plr:FindFirstChild("Backpack")
    local char = plr.Character
    if backpack and (backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")) then return "Murderer" end
    if backpack and (backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")) then return "Sheriff" end
    return "Innocent"
end

local function isPlayerAlive(plr)
    local char = plr.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    return hum and hum.Health > 0
end

local function updateESP()
    if not (namesActive or distanceActive or outlinesActive) then return end

    for plr, bill in pairs(nameBillboards) do if not bill or not bill.Parent then nameBillboards[plr] = nil end end
    for plr, bill in pairs(distanceBillboards) do if not bill or not bill.Parent then distanceBillboards[plr] = nil end end
    for plr, hl in pairs(outlineHighlights) do if not hl or not hl.Parent then outlineHighlights[plr] = nil end end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == localPlayer then continue end
        local char = plr.Character
        if not char or not char:FindFirstChild("Head") then continue end
        local head = char.Head
        local role = getPlayerRole(plr)
        local alive = isPlayerAlive(plr)
        local color = alive and (
            role == "Murderer" and Color3.fromRGB(255,50,50) or
            role == "Sheriff" and Color3.fromRGB(50,150,255) or
            Color3.fromRGB(50,255,120)
        ) or Color3.fromRGB(130,130,130)

        local root = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
        local dist = root and math.floor((head.Position - root.Position).Magnitude) or 0

        if namesActive then
            if not nameBillboards[plr] then
                local bg = Instance.new("BillboardGui") bg.Adornee = head bg.AlwaysOnTop = true bg.Size = UDim2.new(4,0,1.5,0) bg.StudsOffset = Vector3.new(0,3.5,0) bg.Parent = playerGui
                local lbl = Instance.new("TextLabel") lbl.Size = UDim2.new(1,0,1,0) lbl.BackgroundTransparency = 1 lbl.TextStrokeTransparency = 0 lbl.TextStrokeColor3 = Color3.fromRGB(0,0,0) lbl.TextSize = 16 lbl.Font = Enum.Font.GothamBold lbl.Parent = bg
                nameBillboards[plr] = bg
            end
            local bg = nameBillboards[plr]
            bg.TextLabel.Text = "@" .. plr.Name
            bg.TextLabel.TextColor3 = color
        end

        if distanceActive then
            if not distanceBillboards[plr] then
                local bg = Instance.new("BillboardGui") bg.Adornee = head bg.AlwaysOnTop = true bg.Size = UDim2.new(3,0,1,0) bg.StudsOffset = Vector3.new(0,5.5,0) bg.Parent = playerGui
                local lbl = Instance.new("TextLabel") lbl.Size = UDim2.new(1,0,1,0) lbl.BackgroundTransparency = 1 lbl.TextStrokeTransparency = 0 lbl.TextStrokeColor3 = Color3.fromRGB(0,0,0) lbl.TextSize = 11 lbl.Font = Enum.Font.Gotham lbl.Parent = bg
                distanceBillboards[plr] = bg
            end
            local bg = distanceBillboards[plr]
            bg.TextLabel.Text = dist .. " studs"
            bg.TextLabel.TextColor3 = color
        end

        if outlinesActive then
            if not outlineHighlights[plr] then
                local hl = Instance.new("Highlight") hl.Adornee = char hl.FillColor = Color3.fromRGB(180,100,255) hl.FillTransparency = 0.85 hl.OutlineColor = color hl.OutlineTransparency = 0 hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop hl.Parent = playerGui
                outlineHighlights[plr] = hl
            end
            local hl = outlineHighlights[plr]
            hl.OutlineColor = color
            hl.OutlineTransparency = alive and 0 or 0.6
        end
    end
end

local function startESP()
    if espLink then return end
    espLink = RunService.Heartbeat:Connect(updateESP)
end

local function stopESP()
    if espLink then espLink:Disconnect() espLink = nil end
    for _, v in pairs(nameBillboards) do v:Destroy() end
    for _, v in pairs(distanceBillboards) do v:Destroy() end
    for _, v in pairs(outlineHighlights) do v:Destroy() end
    nameBillboards = {} distanceBillboards = {} outlineHighlights = {}
end

local function startHipHeightLoop()
    if hipLoop then return end
    hipLoop = RunService.Heartbeat:Connect(function()
        local char = localPlayer.Character
        if char and char:FindFirstChild("Humanoid") then char.Humanoid.HipHeight = hipHeightValue end
    end)
end

local function startSpeedLoop()
    if speedLoop then return end
    speedLoop = RunService.Heartbeat:Connect(function()
        local char = localPlayer.Character
        if char and char:FindFirstChild("Humanoid") then char.Humanoid.WalkSpeed = speedValue end
    end)
end

local function updateFly()
    if flyConnection then flyConnection:Disconnect() end
    if flyValue <= 0 then return end
    flyConnection = RunService.RenderStepped:Connect(function()
        if flyValue <= 0 then return end
        local char = localPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local cam = workspace.CurrentCamera
        local move = Vector3.new(0,0,0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0,1,0) end
        if move.Magnitude > 0 then root.Velocity = move.Unit * flyValue else root.Velocity = Vector3.new(0,0,0) end
    end)
end

local function handleTeleport(input)
    if not teleportClickActive then return end
    local char = localPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local mouse = game.Players.LocalPlayer:GetMouse()

    if teleportMode == "LeftClick" and input.UserInputType == Enum.UserInputType.MouseButton1 then
        root.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 4, 0))
    elseif teleportMode == "RightClick" and input.UserInputType == Enum.UserInputType.MouseButton2 then
        root.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 4, 0))
    end
end

local function toggleTeleport(state)
    teleportClickActive = state
    if teleportConn then teleportConn:Disconnect() teleportConn = nil end
    if state then
        teleportConn = UserInputService.InputBegan:Connect(handleTeleport)
    end
end

